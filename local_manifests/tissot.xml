<?xml version="1.0" encoding="UTF-8"?>
<!--
  Local manifest for Xiaomi Mi A1 (tissot), Android 9 / Halium 9.0 base.

  Drop this file into .repo/local_manifests/ after:
    repo init -u https://github.com/Halium/android -b halium-9.0 --depth=1

  VERIFY BRANCH NAMES BEFORE USE: device trees for tissot have moved between
  orgs/forks over the years (Flex1911, Linux-On-Sdm6Series, tissot-dev, etc).
  Confirm the branch still exists and still builds before wiring it into CI,
  since abandoned forks are common in this ecosystem.
-->
<manifest>
  <remote name="tissot-halium" fetch="https://github.com/Linux-On-Sdm6Series/" />
  <remote name="xiaomi-msm8953" fetch="https://github.com/Flex1911/" />

  <project name="device_xiaomi_tissot"
           path="device/xiaomi/tissot"
           remote="tissot-halium"
           revision="halium-9.0-4.9" />

  <project name="android_device_xiaomi_msm8953-common"
           path="device/xiaomi/msm8953-common"
           remote="xiaomi-msm8953"
           revision="lineage-16.0-4.9" />

  <project name="android_kernel_xiaomi_msm8953-1"
           path="kernel/xiaomi/msm8953"
           remote="xiaomi-msm8953"
           revision="lineage-16.0-4.9" />

  <project name="proprietary_vendor_xiaomi"
           path="vendor/xiaomi"
           remote="xiaomi-msm8953"
           revision="lineage-16.0" />
</manifest>
